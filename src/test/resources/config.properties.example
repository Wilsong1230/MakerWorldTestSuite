MW_BASE_URL=https://makerworld.com
MW_TIMEOUT_SECONDS=20
MW_SCREENSHOT_ON_FAILURE=true

MW_BROWSER=chrome
MW_HEADLESS=false
MW_CHROME_BINARY=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
MW_CHROMEDRIVER_PATH=

MW_ENABLE_AUTH_SUITE=true
MW_AUTH_MODE=manual_checkpoint
MW_EMAIL=
MW_PASSWORD=
MW_COOKIE_FILE=
MW_CHROME_USER_DATA_DIR=
MW_CHROME_PROFILE_DIR=Default

MW_2CAPTCHA_KEY=
MW_2CAPTCHA_TIMEOUT_SECONDS=90
MW_2CAPTCHA_POLL_SECONDS=3
